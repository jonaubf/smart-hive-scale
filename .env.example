# Copy this file to .env and fill in real values.
# .env is gitignored and never committed.

DEVICE_ID=hive-01

# MQTT broker — factory defaults; change at runtime via config portal (host, port, TLS)
MQTT_BROKER_HOST=203.0.113.1
MQTT_BROKER_PORT=8883
MQTT_USE_TLS=1
MQTT_USERNAME=hive-01
MQTT_PASSWORD=your_mqtt_password

GSM_APN=internet
GSM_USER=
GSM_PASS=
GSM_PIN=

# WiFi AP OTA maintenance mode (override via .env if needed)
WIFI_AP_PASSWORD=beekpr-setup
